# Copy to .env for local development.
# These values come from GCP Secret Manager in Cloud Run.
# Store actual values in 1Password before deleting any local copy.

PORT=8080
GITHUB_MCP_URL=http://localhost:8082
ALLOWED_DOMAIN=example.com
# Set to your Cloud Run URL after first deploy
SERVER_URL=https://your-service.example.com

# GitHub fine-grained PAT (read-only, scoped to your-org + your-repo)
GITHUB_PAT=github_pat_...

# GCP OAuth 2.0 Client ID (web app type)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=GOCSPX-...
